{
  "name": "dnd-lan",
  "private": true,
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "npm --prefix client run build && node ./server/src/util.js copy-client",
    "start": "npm --prefix server run start",
    "test": "npm --prefix server run test",
    "test:client": "npm --prefix client run test",
    "check:utf8": "node scripts/check-utf8.mjs",
    "lint": "npm --prefix client run lint",
    "verify:quick": "npm run check:utf8 && npm run lint && npm run test && npm run build",
    "audit:server": "npm --prefix server audit --omit=dev --audit-level=high",
    "audit:client": "npm --prefix client audit --audit-level=high",
    "perf:budget": "npm run perf:report -- --enforce --initial-js-total=1025000 --largest-js=450000",
    "verify": "npm run check:utf8 && npm run lint && npm run test && npm run test:client && npm run build && npm run e2e && npm run e2e:browser-smoke && npm run e2e:dm-player-flow && npm run e2e:edge-flows && npm run perf:budget && npm run audit:server && npm run audit:client",
    "hooks:enable": "git config core.hooksPath .githooks",
    "preflight": "node scripts/preflight.mjs",
    "images:opt": "node scripts/optimize-images.mjs",
    "perf:report": "node scripts/perf-report.mjs",
    "e2e": "node scripts/e2e.mjs",
    "e2e:browser-smoke": "node scripts/e2e-browser-smoke.mjs",
    "e2e:dm-player-flow": "node scripts/e2e-dm-player-flow.mjs",
    "e2e:edge-flows": "node scripts/e2e-edge-flows.mjs",
    "e2e:visual": "node scripts/e2e-visual.mjs",
    "e2e:shop": "node scripts/e2e-shop-doubleclick.mjs",
    "e2e:transfers": "node scripts/e2e-transfers.mjs",
    "e2e:rpg": "node scripts/e2e-inventory-rpg.mjs",
    "soak:sockets": "npm --prefix server run soak:sockets"
  },
  "devDependencies": {
    "pixelmatch": "^7.1.0",
    "playwright": "^1.56.1",
    "pngjs": "^7.0.0",
    "sharp": "^0.33.5"
  },
  "dependencies": {
    "pino": "^10.3.1"
  }
}
