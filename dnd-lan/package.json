{
  "name": "dnd-lan",
  "private": true,
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "npm --prefix client run build && node ./server/src/util.js copy-client",
    "start": "npm --prefix server run start",
    "test": "npm --prefix server run test",
    "test:client": "npm --prefix client run test",
    "check:utf8": "node scripts/check-utf8.mjs",
    "lint": "npm --prefix client run lint",
    "verify": "npm run check:utf8 && npm run lint && npm run test && npm run build",
    "hooks:enable": "git config core.hooksPath .githooks",
    "preflight": "node scripts/preflight.mjs",
    "images:opt": "node scripts/optimize-images.mjs",
    "perf:report": "node scripts/perf-report.mjs",
    "e2e": "node scripts/e2e.mjs",
    "e2e:visual": "node scripts/e2e-visual.mjs",
    "e2e:shop": "node scripts/e2e-shop-doubleclick.mjs"
  },
  "devDependencies": {
    "pixelmatch": "^7.1.0",
    "playwright": "^1.56.1",
    "pngjs": "^7.0.0",
    "sharp": "^0.33.5"
  },
  "dependencies": {
    "pino": "^10.3.1"
  }
}
